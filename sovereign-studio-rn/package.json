{
  "name": "sovereign-studio-rn",
  "version": "3.0.0",
  "description": "Sovereign Studio V3 - AI-Powered Product Builder for Android",
  "author": "Ouroboros Collective",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "prebuild": "expo prebuild",
    "build:android": "eas build -p android --profile preview",
    "build:android:release": "eas build -p android --profile production",
    "e2e": "node scripts/run-e2e.js",
    "e2e:all": "node scripts/run-e2e.js all",
    "e2e:detox": "node scripts/run-e2e.js detox",
    "e2e:api-fallback": "node scripts/run-e2e.js api",
    "e2e:self-healing": "node scripts/run-e2e.js healing",
    "e2e:auto-fix": "node scripts/run-e2e.js fix",
    "e2e:ci": "node scripts/run-e2e.js ci",
    "workflow:execute": "node scripts/workflow-executor.js",
    "workflow:e2e-trigger": "node scripts/workflow-executor.js e2e-test-trigger",
    "workflow:auto-fix": "node scripts/workflow-executor.js auto-fix-loop",
    "workflow:github": "node scripts/workflow-executor.js github-integration",
    "self-learn": "npx ts-node e2e/self-learn/self-learning-orchestrator.ts",
    "self-learn:run": "npx ts-node e2e/self-learn/self-learning-orchestrator.ts run",
    "self-learn:status": "npx ts-node e2e/self-learn/self-learning-orchestrator.ts status",
    "self-learn:export": "npx ts-node e2e/self-learn/self-learning-orchestrator.ts export",
    "self-learn:patterns": "npx ts-node e2e/self-learn/patterns/pattern-engine.ts",
    "self-learn:routines": "npx ts-node e2e/self-learn/routines/routine-engine.ts"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@google/generative-ai": "^0.24.1",
    "@octokit/rest": "^22.0.1",
    "@react-navigation/native": "^7.1.0",
    "@react-navigation/native-stack": "^7.3.0",
    "@reduxjs/toolkit": "^2.5.1",
    "expo": "~56.0.8",
    "expo-constants": "~17.0.0",
    "expo-secure-store": "~14.0.1",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.23.0",
    "react-native-reanimated": "~3.16.7",
    "react-native-safe-area-context": "^5.2.0",
    "react-native-screens": "~4.5.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native/metro-config": "^0.76.0",
    "@types/react": "~18.3.12",
    "typescript": "~5.7.2"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  }
}
