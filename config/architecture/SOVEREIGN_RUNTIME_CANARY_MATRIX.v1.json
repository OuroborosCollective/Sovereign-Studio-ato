{
  "schemaVersion": "sovereign.runtime-canary-matrix.v1",
  "matrixId": "runtime-canary-coverage-matrix",
  "description": "Releasekritische Backend-, Tool-, Storage-, Client- und Integrationsfamilien mit getrennten statischen, CI- und Live-Beweisen.",
  "revisionBinding": {
    "environment": "SOVEREIGN_REVISION",
    "format": "git-sha-40-lowercase",
    "mustMatchCheckout": true
  },
  "releasePolicy": {
    "mode": "fail-closed",
    "receiptSchemaVersion": "sovereign.runtime-canary-evidence.v1",
    "requiredEvidenceFields": [
      "revision",
      "workflowRunId",
      "status",
      "evidenceSha256"
    ],
    "allowedStatuses": [
      "passed",
      "failed",
      "blocked"
    ]
  },
  "surfaces": [
    {
      "surface": "release-revision-integrity",
      "family": "release",
      "riskClass": "critical",
      "releaseCritical": true,
      "coverageSource": [
        ".github/workflows/release-verification.yml",
        ".github/workflows/sovereign-contract-scan.yml"
      ],
      "staticGate": [
        "checkout-exact-authoritative-revision",
        "full-lowercase-git-sha"
      ],
      "ciCanary": [
        "revision-integrity-gate"
      ],
      "liveCanary": {
        "policy": "excluded",
        "producer": "none",
        "kind": "not-applicable",
        "mutates": false,
        "externalCost": false,
        "cleanup": "none",
        "exclusion": {
          "reason": "Revisionsintegrität ist ein CI- und Artefaktbindungsvertrag und keine produktive Fachfunktion.",
          "trackingIssue": "none",
          "reviewRequired": true
        }
      },
      "evidenceFields": [
        "revision",
        "workflowRunId",
        "status",
        "evidenceSha256",
        "checkedOutHead"
      ],
      "ownerGate": false,
      "budgetGate": "none"
    },
