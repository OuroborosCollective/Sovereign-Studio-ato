name: 🤖 Issue → Code Agent (No AI)

on:
  issues:
    types: [opened, labeled]
  schedule:
    - cron: "*/30 * * * *"

permissions:
  contents: write
  issues: write
  pull-requests: write

jobs:
  build-from-issue:
    if: contains(github.event.issue.labels.*.name, 'autonomous-task') || github.event_name == 'schedule'
    runs-on: ubuntu-latest

    steps:
      - name: 🧬 Checkout
        uses: actions/checkout@v4

      - name: ⚙️ Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: 20

      - name: 📦 Install
        run: npm install || true

      - name: 🔍 Collect Issues
        id: issues
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          node << 'EOF'
          const { Octokit } = require("octokit");
          const fs = require("fs");

          const octokit = new Octokit({ auth: process.env.GH_TOKEN });
          const [owner, repo] = process.env.GITHUB_REPOSITORY.split('/');

          (async () => {
            const res = await octokit.rest.issues.listForRepo({
              owner,
              repo,
              state: "open",
              labels: "autonomous-task",
              per_page: 5
            });

            const issues = res.data.filter(i => !i.pull_request);
            fs.writeFileSync("issues.json", JSON.stringify(issues, null, 2));
          })();
          EOF

      - name: 🧠 Generate Code (Template Engine)
        run: |
          node << 'EOF'
          const fs = require("fs");
          const path = require("path");

          const issues = JSON.parse(fs.readFileSync("issues.json", "utf8"));
          let outputs = [];

          function toFileName(title) {
            return title.toLowerCase().replace(/[^a-z0-9]/g, "-");
          }

          function generateService(name) {
            return `export class ${name}Service {
  async execute() {
    try {
      console.log("${name}Service running");
      return true;
    } catch (err) {
      console.error("${name}Service error:", err);
      throw err;
    }
  }
}`;
          }

          function generateHook(name) {
            return `import { useState } from 'react';

export function use${name}() {
  const [state, setState] = useState(null);

  const run = async () => {
    console.log("${name} hook triggered");
  };

  return { state, run };
}`;
          }

          function generateApi(name) {
            return `export async function ${name}Api() {
  const res = await fetch('/api/${name}');
  return res.json();
}`;
          }

          for (const issue of issues) {
            const base = toFileName(issue.title);
            let filePath = "";
            let content = "";

            if (issue.labels.find(l => l.name === "service")) {
              const className = base.replace(/(^\w)/, c => c.toUpperCase());
              filePath = `src/services/${base}.ts`;
              content = generateService(className);
            } 
            else if (issue.labels.find(l => l.name === "hook")) {
              const name = base.replace(/(^\w)/, c => c.toUpperCase());
              filePath = `src/hooks/use${name}.ts`;
              content = generateHook(name);
            } 
            else {
              filePath = `src/api/${base}.ts`;
              content = generateApi(base);
            }

            fs.mkdirSync(path.dirname(filePath), { recursive: true });
            fs.writeFileSync(filePath, content);

            outputs.push({ issueNumber: issue.number, filePath });
          }

          fs.writeFileSync("generated.json", JSON.stringify(outputs, null, 2));
          EOF

      - name: 🪄 Commit & Push
        run: |
          git config user.name "no-ai-agent"
          git config user.email "bot@users.noreply.github.com"

          BRANCH=auto/noai-${{ github.run_id }}
          git checkout -b $BRANCH

          git add .
          git diff --cached --quiet && echo "No changes" && exit 0

          git commit -m "🤖 Generated code from issues (no AI)"
          git push origin $BRANCH

      - name: 🚀 Create PR
        uses: peter-evans/create-pull-request@v6
        with:
          branch: auto/noai-${{ github.run_id }}
          title: "🤖 Issue → Code (No AI)"
          body: |
            Generated via rule-based engine (no external API).
          base: main
          draft: true

      - name: ✅ Mark Issues processed
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          node << 'EOF'
          const { Octokit } = require("octokit");
          const fs = require("fs");

          const octokit = new Octokit({ auth: process.env.GH_TOKEN });
          const issues = JSON.parse(fs.readFileSync("issues.json", "utf8"));
          const [owner, repo] = process.env.GITHUB_REPOSITORY.split('/');

          (async () => {
            for (const issue of issues) {
              await octokit.rest.issues.createComment({
                owner,
                repo,
                issue_number: issue.number,
                body: "🤖 Generated via rule-based engine (no AI)."
              });

              await octokit.rest.issues.addLabels({
                owner,
                repo,
                issue_number: issue.number,
                labels: ["processed"]
              });
            }
          })();
          EOF
