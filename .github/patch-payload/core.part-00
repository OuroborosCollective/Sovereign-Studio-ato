-name: Dependabot Auto-Merge
-
-on:
-  pull_request_target:
-    types: [opened, synchronize, reopened]
-
-# Cancel in-progress runs for the same PR
-concurrency:
-  group: ${{ github.workflow }}-${{ github.event.pull_request.number }}
-  cancel-in-progress: true
-
-jobs:
-  # Job to check if the PR is from Dependabot and merge it
-  automerge:
-    name: Auto-Merge Dependabot PR
-    runs-on: ubuntu-latest
-    # Only run if the PR is from Dependabot
-    if: ${{ github.actor == 'dependabot[bot]' }}
-    steps:
-      - name: Fetch PR Info
-        id: pr_info
-        uses: actions/github-script@v7
-        with:
-          script: |
-            const prNumber = context.payload.pull_request.number;
-            const pr = await github.rest.pulls.get({
-              owner: context.repo.owner,
-              repo: context.repo.repo,
-              pull_number: prNumber
-            });
-            
-            // Check if PR is mergeable
-            core.setOutput('mergeable', pr.data.mergeable);
-            core.setOutput('state', pr.data.state);
-            
-            // Get the head branch SHA for status checks
-            core.setOutput('head_sha', pr.data.head.sha);
-            core.setOutput('pr_number', prNumber);
-            
-            console.log(`PR #${prNumber}: mergeable=${pr.data.mergeable}, state=${pr.data.state}`);
-
-      - name: Wait for CI to Pass
-        id: wait_ci
-        uses: actions/github-script@v7
-        with:
-          script: |
-            const headSha = '${{ steps.pr_info.outputs.head_sha }}';
-            
-            // Wait for all required checks to pass
-            const timeout = 300; // 5 minutes max
-            const interval = 10; // check every 10 seconds
-            
-            for (let elapsed = 0; elapsed < timeout; elapsed += interval) {
-              // Get all check runs for this PR
-              const { data: checks } = await github.rest.checks.listForRef({
-                owner: context.repo.owner,
-                repo: context.repo.repo,
-                ref: headSha,
-                status: 'completed'
-              });
-              
-              // Also check in-progress runs
-              const { data: pendingChecks } = await github.rest.checks.listForRef({
-                owner: context.repo.owner,
-                repo: context.repo.repo,
-                ref: headSha,
-                status: 'in_progress'
-              });
-              
-              const allRuns = [...checks.check_runs, ...pendingChecks.check_runs];
-              
-              // Check if ALL required checks have passed (only look at completed checks)
-              const completedChecks = checks.check_runs;
-              const allPassed = completedChecks.length > 0 && completedChecks.every(check => 
-                check.conclusion === 'success' || check.conclusion === 'skipped'
-              );
-              
-              if (allPassed) {
-                console.log('All CI checks passed!');
-                core.setOutput('ci_passed', 'true');
-                core.exit(0);
-              }
-              
-              if (pendingChecks.check_runs.length > 0) {
-                console.log(`Waiting for ${pendingChecks.check_runs.length} checks to complete... (${elapsed}s elapsed)`);
-              }
-              
-              await new Promise(resolve => setTimeout(resolve, interval * 1000));
-            }
-            
-            console.log('Timeout waiting for CI');
-            core.setOutput('ci_passed', 'false');
-            core.exit(1);
-
-      - name: Merge PR
-        if: ${{ steps.wait_ci.outputs.ci_passed == 'true' && steps.pr_info.outputs.mergeable == 'true' }}
-        uses: actions/github-script@v7
-        with:
-          script: |
-            const prNumber = '${{ steps.pr_info.outputs.pr_number }}';
-            
-            try {
-              // Merge the PR using squash merge
-              await github.rest.pulls.merge({
-                owner: context.repo.owner,
-                repo: context.repo.repo,
-                pull_number: parseInt(prNumber),
-                merge_method: 'squash'
-              });
-              
-              console.log(`✅ Successfully auto-merged Dependabot PR #${prNumber}`);
-            } catch (error) {
-              // Check if already merged (status 405) or other errors
-              if (error.status === 405 || error.message?.includes('Pull request is already merged')) {
-                console.log('PR was already merged');
-              } else {
-                console.log('Error merging PR:', error.message);
-                core.setOutput('merge_error', 'true');
-              }
-            }
-
-      - name: Success Message
-        if: ${{ steps.wait_ci.outputs.ci_passed == 'true' }}
-        run: |
-          echo "✅ Dependabot PR #${{ steps.pr_info.outputs.pr_number }} has been auto-merged!"
