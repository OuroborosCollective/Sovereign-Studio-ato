index 0000000000000000000000000000000000000000..cdc517275d73c8efaab34380816c047f595e91e4
--- /dev/null
+++ b/backend/agent_runtime/sovereign_local_runner.py
@@ -0,0 +1,710 @@
+"""Sovereign Local Runner — Background Worker for Sovereign Agent Jobs.
+
+This module provides the sovereign-local-runner as a background thread that polls
+the database for jobs in "provisioning" status and drives them to completion.
+"""
+
+from __future__ import annotations
+
+import json
+import os
+import threading
+import time
+from dataclasses import dataclass, field
+from pathlib import Path
+from typing import Any
+
+import psycopg2
+import psycopg2.pool
+import psycopg2.extras
+
+from .contracts import normalize_agent_paths, sanitize_agent_text
+
+WORKER_AI_BASE = os.getenv(
+    "WORKER_AI_PROXY_URL",
+    "https://sovereign-llm-proxy.projectouroboroscollective.workers.dev",
+)
+WORKER_AI_TIMEOUT = 30
+RUNNER_ALLOWED_ACTIONS = frozenset({
+    "file_read",
+    "file_write",
+    "git_status",
+    "git_diff",
+    "test",
+    "done",
+    "fail",
+})
+RUNNER_EXECUTABLE_TOOLS = RUNNER_ALLOWED_ACTIONS - {"done", "fail"}
+POLL_INTERVAL = max(1, int(os.getenv("SOVEREIGN_RUNNER_POLL_SECS", "5")))
+MAX_CONCURRENT_JOBS = max(1, min(int(os.getenv("SOVEREIGN_RUNNER_MAX_JOBS", "3")), 8))
+ENABLED = os.getenv("SOVEREIGN_RUNNER_ENABLED", "false").lower() == "true"
+
+
+def _llm_headers() -> dict[str, str]:
+    headers = {"Content-Type": "application/json"}
+    api_key = os.getenv("WORKER_AI_PROXY_KEY", "")
+    if api_key:
+        headers["Authorization"] = f"Bearer {api_key}"
+    return headers
+
+
+def _parse_llm_action(raw_content: Any) -> tuple[dict[str, Any] | None, str]:
+    """Parse one explicit JSON action. Natural-language inference is forbidden."""
+
+    payload: Any = raw_content
+    if isinstance(payload, str):
+        content = payload.strip()
+        if content.startswith("```"):
+            lines = content.splitlines()
+            if len(lines) >= 3 and lines[-1].strip() == "```":
+                content = "\n".join(lines[1:-1]).strip()
+        try:
+            payload = json.loads(content)
+        except json.JSONDecodeError as exc:
+            return None, f"LLM response must be one JSON object: {exc.msg}"
+
+    if not isinstance(payload, dict):
+        return None, "LLM response must be a JSON object"
+
+    if "tool" not in payload and isinstance(payload.get("name"), str):
+        embedded_parameters = payload.get("parameters")
+        if not isinstance(embedded_parameters, dict):
+            embedded_parameters = {
+                key: value for key, value in payload.items()
+                if key not in {"name", "parameters"}
+            }
+        payload = {"tool": payload["name"], "parameters": embedded_parameters}
+
+    tool_name = payload.get("tool")
+    parameters = payload.get("parameters", {})
+    if not isinstance(tool_name, str) or tool_name not in RUNNER_ALLOWED_ACTIONS:
+        return None, "LLM requested an unknown or forbidden tool"
+    if not isinstance(parameters, dict):
+        return None, "LLM tool parameters must be a JSON object"
+
+    return {"tool": tool_name, "parameters": parameters}, ""
+
+
+def call_llm_for_next_action(
+    mission: str,
+    repo_url: str | None,
+    branch: str,
+    workspace_path: str | None,
+    tool_results: list[dict[str, Any]],
+    max_iterations: int = 20,
+) -> tuple[dict[str, Any] | None, str]:
+    context_lines = []
+    for result in tool_results[-5:]:
+        tool = result.ge