     return headers
 
 
+def _parse_llm_action(raw_content: Any) -> tuple[dict[str, Any] | None, str]:
+    """Parse one explicit JSON action. Natural-language inference is forbidden."""
+
+    payload: Any = raw_content
+    if isinstance(payload, str):
+        content = payload.strip()
+        if content.startswith("```"):
+            lines = content.splitlines()
+            if len(lines) >= 3 and lines[-1].strip() == "```":
+                content = "\n".join(lines[1:-1]).strip()
+        try:
+            payload = json.loads(content)
+        except json.JSONDecodeError as exc:
+            return None, f"LLM response must be one JSON object: {exc.msg}"
+
+    if not isinstance(payload, dict):
+        return None, "LLM response must be a JSON object"
+
+    if "tool" not in payload and isinstance(payload.get("name"), str):
+        embedded_parameters = payload.get("parameters")
+        if not isinstance(embedded_parameters, dict):
+            embedded_parameters = {
+                key: value for key, value in payload.items()
+                if key not in {"name", "parameters"}
+            }
+        payload = {"tool": payload["name"], "parameters": embedded_parameters}
+
+    tool_name = payload.get("tool")
+    parameters = payload.get("parameters", {})
+    if not isinstance(tool_name, str) or tool_name not in RUNNER_ALLOWED_ACTIONS:
+        return None, "LLM requested an unknown or forbidden tool"
+    if not isinstance(parameters, dict):
+        return None, "LLM tool parameters must be a JSON object"
+
+    return {"tool": tool_name, "parameters": parameters}, ""
+
+
