inue
+                reason = f"LLM unavailable or invalid: {error or 'unknown response'}"
+                _update_job_runner(conn, job_id, "failed", blocker=reason)
+                _job_events(job_id, [{"stage": "job_failed_llm", "level": "error", "message": reason}], conn)
+                return
+
+            tool_name = llm_response["tool"]
+            parameters = llm_response["parameters"]
+
+            if tool_name == "done":
+                _update_job_runner(conn, job_id, "validating")
+                changed_files, diff_summary, test_summary, evidence_error = _collect_workspace_evidence(state, root)
+                if evidence_error:
+                    reason = f"completion_evidence_error: {evidence_error}"
+                    _update_job_runner(
+                        conn,
+                        job_id,
+                        "blocked",
+                        blocker=reason,
+                        changed_files=changed_files,
+                        diff_summary=diff_summary,
+                        test_summary=test_summary,
+                    )
+                    _job_events(job_id, [{"stage": "completion_blocked", "level": "warning", "message": reason}], conn)
+                    return
+
+                from .evidence_gate import EvidenceGateInput, evaluate_agent_evidence
+
+                gate = evaluate_agent_evidence(EvidenceGateInput(
+                    job_id=job_id,
+                    workspace_path=state.workspace_path,
+                    mission=state.mission,
+                    changed_files=changed_files,
+                    diff_summary=diff_summary,
+                    test_summary=test_summary,
+                    can_prepare_draft_pr=True,
+                ))
+                if not gate.passed:
+                    reason = f"completion_evidence_missing: {gate.reason}"
+                    _update_job_runner(
+                        conn,
+                        job_id,
+                        "blocked",
+                        blocker=reason,
+                        changed_files=changed_files,
+                        diff_summary=diff_summary,
+                        test_summary=test_summary,
+                    )
+                    _job_events(job_id, [{"stage": "completion_blocked", "level": "warning", "message": reason}], conn)
+                    return
+
+                summary = sanitize_agent_text(str(parameters.get("summary") or "Job completed."), 1200)
+                _update_job_runner(
+                    conn,
+                    job_id,
+                    "completed",
+                    changed_files=changed_files,
+                    diff_summary=diff_summary,
+                    test_summary=test_summary,
+                )
+                _job_events(job_id, [{"stage": "job_completed_by_runner", "level": "success", "message": summary}], conn)
+                return
+
+            if tool_name == "fail":
+                reason = sanitize_agent_text(str(parameters.get("reason") or "Job failed."), 1200)
+                _update_job_runner(conn, job_id, "failed", blocker=reason)
+                _job_events(job_id, [{"stage": "job_failed_by_runner", "level": "error", "message": reason}], conn)
+                return
+
+            repo_path = str(Path(state.workspace_path) / "repo")
+            tool_result = execute_tool_call(tool_name, parameters, repo_path)
+            state.tool_results.append(tool_result)
+            _job_events(job_id, tool_result.get("events", []), conn)
+
+            if tool_result["status"] in {"blocked", "error"}:
+                blocker = (
+                    tool_result.get("blocker")
+                    or tool_result.get("error")
+                    or f"Tool '{tool_name}' failed"
+                )
+                _update_job_runner(conn, job_id, "failed", blocker=blocker)
+                _job_events(job_id, [{"stage": "job_failed_tool", "level": "error", "message": blocker}], conn)
+                return
+
+            changed_files, diff_summary, test_summary, _ = _collect_workspace_evidence(state, root)
+            _update_job_runner(
+                conn,
+                job_id,
+                "running",
+                changed_files=changed_files,
+                diff_summary=diff_summary,
+                test_summary=test_summary,
+            )
+
+        reason = f"Job reached max iterations ({max_iterations}) without completing"
+        _update_job_runner(conn, job_id, "failed", blocker=reason)
+        _job_events(job_id, [{"stage": "job_failed_max_iterations", "level": "error", "message": reason}], conn)
+
+    except Exception as exc:
+        try:
+            conn.rollback()
+        except Exception:
+            pass
+        reason = sanitize_agent_text(
+            f"runner_exception:{type(exc).__name__}: {exc}",
+            1200,
+        )
+        try:
+            _update_job_runner(conn, job_id, "failed", blocker=reason)
+            _job_events(job_id, [{"stage": "runner_exception", "level": "error", "message": reason}], conn)
+        except Exception as persist_error:
+            print(
+                "[runner] Failed to persist terminal runner error "
+                f"for {job_id}: {type(persist_error).__name__}"
+            )
+        print(f"[runner] Job {job_id} failed with a persisted runner exception")
+    finally:
+        runner_pool.putconn(conn)
+
+
+
+def _claim_provisioning_jobs(
+    runner_pool: psycopg2.pool.ThreadedConnectionPool,
+    limit: int,
+) -> tuple[str, ...]:
+    if limit <= 0:
+        return ()
+    conn = runner_pool.getconn()
+    try:
+        with conn.cursor() as cursor:
+            cursor.execute(
+                """
+                WITH candidates AS (
+                    SELECT job_id
+                    FROM sovereign_agent_jobs
+                    WHERE status = 'provisioning'
+                      AND executor = 'sovereign-local-runner'
+                      AND created_at < NOW() - INTERVAL '5 seconds'
+                    ORDER BY created_at ASC
+                    FOR UPDATE SKIP LOCKED
+                    LIMIT %s
+                )
+                UPDATE sovereign_agent_jobs AS jobs
+                SET status = 'running',
+                    started_at = COALESCE(jobs.started_at, NOW()),
+                    blocker = NULL,
+                    updated_at = NOW()
+                FROM candidates
+                WHERE jobs.job_id = candidates.job_id
+                RETURNING jobs.job_id
+                """,
+                (limit,),
+            )
+            claimed = tuple(str(row[0]) for row in cursor.fetchall())
+        conn.commit()
+        return claimed
+    except Exception:
+        conn.rollback()
+        raise
+    finally:
+        runner_pool.putconn(conn)
+
+
+class SovereignRunnerDaemon(threading.Thread):
+    def __init__(
+        self,
+        runner_pool: psycopg2.pool.ThreadedConnectionPool,
+        workspace_root: str | None,
+    ):
+        super().__init__(name="sovereign-local-runner", daemon=True)
+        self._pool = runner_pool
+        self._workspace_root = workspace_root
+        self._stop_event = threading.Event()
+        self._job_threads: dict[str, threading.Thread] = {}
+
+    def stop(self) -> None:
+        self._stop_event.set()
+        for thread in list(self._job_threads.values()):
+            thread.join(timeout=10)
+        self._pool.closeall()
+        print("[runner] sovereign-local-runner stopped")
+
+    def run(self) -> None:
+        print(
+            "[runner] sovereign-local-runner started "
+            f"(poll={POLL_INTERVAL}s, max_jobs={MAX_CONCURRENT_JOBS})"
+        )
+        while not self._stop_event.is_set():
+            try:
+                self._poll_and_dispatch()
+            except Exception as exc:
+                message = sanitize_agent_text(
+                    f"{type(exc).__name__}: {exc}",
+                    600,
+                )
+                print(f"[runner] poll error: {message}")
+            self._stop_event.wait(timeout=POLL_INTERVAL)
+        for thread in list(self._job_threads.values()):
+            thread.join(timeout=10)
+
+    def _poll_and_dispatch(self) -> None:
+        finished = [
+            job_id
+            for job_id, thread in self._job_threads.items()
+            if not thread.is_alive()
+        ]
+        for job_id in finished:
+            del self._job_threads[job_id]
+
+        if not ENABLED:
+            return
+
+        capacity = MAX_CONCURRENT_JOBS - len(self._job_threads)
+        for job_id in _claim_provisioning_jobs(self._pool, capacity):
+            thread = threading.Thread(
+                target=run_job_to_completion,
+                args=(job_id, self._pool, self._workspace_root),
+                name=f"runner-job-{job_id[:12]}",
+                daemon=True,
+            )
+            self._job_threads[job_id] = thread
+            thread.start()
+            print(f"[runner] Claimed and dispatched job {job_id}")
+
+
+_runner_daemon: SovereignRunnerDaemon | None = None
+_runner_lock = threading.Lock()
+
+
+def register_sovereign_runner(workspace_root: str | None = None) -> SovereignRunnerDaemon | None:
+    """Start one daemon in this process. Cross-process safety comes from DB claims."""
+
+    global _runner_daemon
+    with _runner_lock:
+        if _runner_daemon is not None:
+            return _runner_daemon
+        if not ENABLED:
+            print("[runner] disabled; set SOVEREIGN_RUNNER_ENABLED=true in a dedicated runner process")
+            return None
+        pool = _create_runner_pool()
+        daemon = SovereignRunnerDaemon(pool, workspace_root)
+        daemon.start()
+        _runner_daemon = daemon
+        return daemon
+
+
+def stop_sovereign_runner() -> None:
+    global _runner_daemon
+    if _runner_daemon is not None:
+        _runner_daemon.stop()
+        _runner_daemon = None
