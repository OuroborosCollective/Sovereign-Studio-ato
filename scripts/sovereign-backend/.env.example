# =============================================================================
# Sovereign Backend Environment Configuration
# =============================================================================
# Copy this file to .env and configure for your environment.
# IMPORTANT: Never commit .env to version control!
# =============================================================================

# PostgreSQL Configuration
# IMPORTANT: Use 'db' when running inside Docker (docker-compose)
# This is the hostname of PostgreSQL in the supabase_default network
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here

# Admin API Key
# Generate a secure key: openssl rand -hex 32
ADMIN_API_KEY=your_admin_api_key_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_here

# LLM Proxy (optional)
LLM_PROXY_KEY=your_llm_proxy_key_here

# Flask Environment
FLASK_ENV=production

# OpenHands Integration
OPENHANDS_API_URL=http://openhands-enterprise-openhands-1:8000
TOOLCHAIN_BASE_URL=http://127.0.0.1:8001

# Cloudflare AI Gateway Configuration (BYOK)
# Get your Gateway Token from Cloudflare Dashboard: AI → AI Gateway → Settings
AI_GATEWAY_ID=gatter
AI_GATEWAY_ACCOUNT=your_cloudflare_account_id
AI_GATEWAY_TOKEN=your_ai_gateway_token

# Worker AI Proxy (optional - for custom Worker AI endpoint)
WORKER_AI_PROXY_URL=https://sovereign-llm-proxy.projectouroboroscollective.workers.dev
WORKER_AI_PROXY_KEY=your_worker_ai_proxy_key
