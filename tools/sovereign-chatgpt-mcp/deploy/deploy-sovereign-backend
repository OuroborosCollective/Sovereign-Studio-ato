#!/usr/bin/env bash
set -Eeuo pipefail

DIGEST="${1:-}"
EXPECTED_REVISION="${2:-}"
IMAGE_REPOSITORY="${SOVEREIGN_BACKEND_IMAGE_REPOSITORY:-}"
ENV_FILE="${SOVEREIGN_BACKEND_ENV_FILE:-/run/secrets/sovereign-backend.env}"
MANAGED_ENV_FILE="${SOVEREIGN_BACKEND_MANAGED_ENV_FILE:-/opt/sovereign-chatgpt-tools/backend-runtime.env}"
CONTAINER="sovereign-backend"
CANDIDATE="sovereign-backend-candidate"
PREVIOUS_IMAGE=""
PREVIOUS_REPO_DIGEST=""
PREVIOUS_DIGEST=""
PREVIOUS_REVISION=""
NEW_IMAGE=""
ADMIN_CANARY=""
ROLLBACK_RECEIPT_FILE="${SOVEREIGN_BACKEND_ROLLBACK_RECEIPT_FILE:-/opt/sovereign-chatgpt-tools/runtime-evidence/backend-rollback-receipt.json}"
OWNER_INPUT_HOST_ROOT="/opt/sovereign-owner-managed"
OWNER_INPUT_CONTAINER_ROOT="/opt/sovereign-owner-managed"
WORKSPACE_HOST_ROOT="/opt/sovereign-agent-workspaces"
WORKSPACE_CONTAINER_ROOT="/var/lib/sovereign-agent/workspaces"
WORKSPACE_UID="10001"
WORKSPACE_GID="10001"
BROKER_SOCKET="${SOVEREIGN_MCP_BROKER_SOCKET:-/run/sovereign-chatgpt-broker/operator.sock}"
BROKER_RUNTIME_DIR="$(dirname "$BROKER_SOCKET")"
BROKER_GID=""

fail() {
  printf 'deploy blocked: %s\n' "$*" >&2
  exit 1
}

[[ "$DIGEST" =~ ^sha256:[0-9a-f]{64}$ ]] || fail "invalid image digest"
[[ "$EXPECTED_REVISION" =~ ^[0-9a-f]{40}$ ]] || fail "invalid expected revision"
[[ -n "$IMAGE_REPOSITORY" ]] || fail "SOVEREIGN_BACKEND_IMAGE_REPOSITORY is missing"
[[ -f "$ENV_FILE" ]] || fail "backend env file is missing"
[[ -f "$MANAGED_ENV_FILE" ]] || fail "backend managed env file is missing"
umask 077
if [[ -e "$OWNER_INPUT_HOST_ROOT" || -L "$OWNER_INPUT_HOST_ROOT" ]]; then
  [[ -d "$OWNER_INPUT_HOST_ROOT" && ! -L "$OWNER_INPUT_HOST_ROOT" ]] \
    || fail "owner input host root is not a regular directory"
else
  mkdir -p "$OWNER_INPUT_HOST_ROOT"
fi
[[ -d "$OWNER_INPUT_HOST_ROOT" && ! -L "$OWNER_INPUT_HOST_ROOT" ]] \
  || fail "owner input host root is not a regular directory"
chmod 0700 "$OWNER_INPUT_HOST_ROOT"
[[ -w "$OWNER_INPUT_HOST_ROOT" && -x "$OWNER_INPUT_HOST_ROOT" ]] \
  || fail "owner input host root is not writable and searchable"
if [[ -e "$WORKSPACE_HOST_ROOT" || -L "$WORKSPACE_HOST_ROOT" ]]; then
  [[ -d "$WORKSPACE_HOST_ROOT" && ! -L "$WORKSPACE_HOST_ROOT" ]] \
    || fail "workspace host root is not a regular directory"
else
  mkdir -p "$WORKSPACE_HOST_ROOT"
fi
chown "$WORKSPACE_UID:$WORKSPACE_GID" "$WORKSPACE_HOST_ROOT"
chmod 0770 "$WORKSPACE_HOST_ROOT"
[[ -w "$WORKSPACE_HOST_ROOT" && -x "$WORKSPACE_HOST_ROOT" ]] \
  || fail "workspace host root is not writable and searchable"
[[ -S "$BROKER_SOCKET" ]] || fail "authoritative MCP broker socket is missing"
BROKER_GID="$(stat -c '%g' "$BROKER_SOCKET")"
[[ "$BROKER_GID" =~ ^[0-9]+$ ]] || fail "authoritative MCP broker group could not be resolved"

NEW_IMAGE="${IMAGE_REPOSITORY}@${DIGEST}"
docker pull "$NEW_IMAGE" >/dev/null

ACTUAL_DIGEST="$(docker image inspect --format '{{index .RepoDigests 0}}' "$NEW_IMAGE" 2>/dev/null || true)"
[[ "$ACTUAL_DIGEST" == *"@$DIGEST" ]] || fail "pulled image digest does not match"

IMAGE_REVISION="$(docker image inspect --format '{{index .Config.Labels "org.opencontainers.image.revision"}}' "$NEW_IMAGE" 2>/dev/null || true)"
[[ "$IMAGE_REVISION" == "$EXPECTED_REVISION" ]] || fail "image revision label does not match expected commit"

for network in supabase_default areloria_arelorian-network sovereign-private; do
  docker network inspect "$network" >/dev/null 2>&1 || fail "required docker network missing: $network"
done

docker rm -f "$CANDIDATE" >/dev/null 2>&1 || true
docker run -d \
  --name "$CANDIDATE" \
  --env-file "$ENV_FILE" \
  --env-file "$MANAGED_ENV_FILE" \
  --env "SOVEREIGN_IMAGE_DIGEST=$DIGEST" \
  --env "SOVEREIGN_SOURCE_REVISION=$EXPECTED_REVISION" \
  --env "SOVEREIGN_MCP_BROKER_SOCKET=$BROKER_SOCKET" \
  --env "SOVEREIGN_LLM_ROUTE_SCANNER_ENABLED=0" \
  --env "SOVEREIGN_AGENT_WORKSPACE_ROOT=$WORKSPACE_CONTAINER_ROOT" \
  --env "SOVEREIGN_AGENT_WORKSPACE_UID=$WORKSPACE_UID" \
  --env "SOVEREIGN_AGENT_WORKSPACE_GID=$WORKSPACE_GID" \
  --network supabase_default \
  --volume /opt/secure:/opt/secure:ro \
  --volume "$OWNER_INPUT_HOST_ROOT:$OWNER_INPUT_CONTAINER_ROOT:rw" \
  --volume "$WORKSPACE_HOST_ROOT:$WORKSPACE_CONTAINER_ROOT:rw" \
  --volume "$BROKER_RUNTIME_DIR:$BROKER_RUNTIME_DIR:ro" \
  --group-add "$BROKER_GID" \
  --label "org.opencontainers.image.revision=$EXPECTED_REVISION" \
  "$NEW_IMAGE" >/dev/null

docker network connect areloria_arelorian-network "$CANDIDATE"
docker network connect sovereign-private "$CANDIDATE"

candidate_cleanup() {
  docker rm -f "$CANDIDATE" >/dev/null 2>&1 || true
}
trap candidate_cleanup EXIT

HEALTH=""
for attempt in $(seq 1 12); do
  HEALTH="$(docker exec "$CANDIDATE" python3 -c 'import urllib.request; print(urllib.request.urlopen("http://127.0.0.1:8787/health", timeout=4).read().decode())' 2>/dev/null || true)"
  if printf '%s' "$HEALTH" | grep -q '"ok"[[:space:]]*:[[:space:]]*true'; then
    break
  fi
  sleep 5
done
printf '%s' "$HEALTH" | grep -q '"ok"[[:space:]]*:[[:space:]]*true' || {
  docker logs "$CANDIDATE" --tail 150 >&2 || true
  fail "candidate health check failed"
}

PREVIOUS_IMAGE="$(docker inspect --format '{{.Config.Image}}' "$CONTAINER" 2>/dev/null || true)"
if [[ -n "$PREVIOUS_IMAGE" ]]; then
  PREVIOUS_REPO_DIGEST="$(docker image inspect --format '{{index .RepoDigests 0}}' "$PREVIOUS_IMAGE" 2>/dev/null || true)"
  PREVIOUS_DIGEST="${PREVIOUS_REPO_DIGEST##*@}"
  PREVIOUS_REVISION="$(docker image inspect --format '{{index .Config.Labels "org.opencontainers.image.revision"}}' "$PREVIOUS_IMAGE" 2>/dev/null || true)"
  [[ "$PREVIOUS_DIGEST" =~ ^sha256:[0-9a-f]{64}$ ]] || fail "previous backend image has no immutable digest"
  [[ "$PREVIOUS_REVISION" =~ ^[0-9a-f]{40}$ ]] || fail "previous backend image has no valid revision label"
fi

docker rm -f "$CONTAINER" >/dev/null 2>&1 || true

start_production() {
  local image="$1"
  local revision="$2"
  local runtime_digest="$3"
  docker run -d \
    --name "$CONTAINER" \
    --restart unless-stopped \
    --env-file "$ENV_FILE" \
    --env-file "$MANAGED_ENV_FILE" \
    --env "SOVEREIGN_IMAGE_DIGEST=$runtime_digest" \
    --env "SOVEREIGN_SOURCE_REVISION=$revision" \
    --env "SOVEREIGN_MCP_BROKER_SOCKET=$BROKER_SOCKET" \
    --env "SOVEREIGN_LLM_ROUTE_SCANNER_ENABLED=1" \
    --env "SOVEREIGN_LLM_ROUTE_SCANNER_INTERVAL_SECONDS=3600" \
    --env "SOVEREIGN_LLM_ROUTE_SCANNER_INITIAL_DELAY_SECONDS=30" \
    --env "SOVEREIGN_LLM_ROUTE_SCANNER_MAX_CANDIDATES=24" \
    --env "SOVEREIGN_LLM_ROUTE_SCANNER_MAX_WORKERS=4" \
    --env "SOVEREIGN_AGENT_WORKSPACE_ROOT=$WORKSPACE_CONTAINER_ROOT" \
    --env "SOVEREIGN_AGENT_WORKSPACE_UID=$WORKSPACE_UID" \
    --env "SOVEREIGN_AGENT_WORKSPACE_GID=$WORKSPACE_GID" \
    --network supabase_default \
    --volume /opt/secure:/opt/secure:ro \
    --volume "$OWNER_INPUT_HOST_ROOT:$OWNER_INPUT_CONTAINER_ROOT:rw" \
    --volume "$WORKSPACE_HOST_ROOT:$WORKSPACE_CONTAINER_ROOT:rw" \
    --volume "$BROKER_RUNTIME_DIR:$BROKER_RUNTIME_DIR:ro" \
    --group-add "$BROKER_GID" \
    --label "org.opencontainers.image.revision=$revision" \
    -p 127.0.0.1:8788:8787 \
    "$image" >/dev/null
  docker network connect areloria_arelorian-network "$CONTAINER"
  docker network connect sovereign-private "$CONTAINER"
}

start_production "$NEW_IMAGE" "$EXPECTED_REVISION" "$DIGEST"

wait_for_host_health() {
  local health=""
  for attempt in $(seq 1 12); do
    health="$(python3 -c 'import urllib.request; print(urllib.request.urlopen("http://127.0.0.1:8788/health", timeout=4).read().decode())' 2>/dev/null || true)"
    if printf '%s' "$health" | grep -q '"ok"[[:space:]]*:[[:space:]]*true'; then
      printf '%s' "$health"
      return 0
    fi
    sleep 5
  done
  printf '%s' "$health"
  return 1
}

restore_previous() {
  docker rm -f "$CONTAINER" >/dev/null 2>&1 || true
  if [[ -n "$PREVIOUS_IMAGE" && -n "$PREVIOUS_DIGEST" && -n "$PREVIOUS_REVISION" ]]; then
    start_production "$PREVIOUS_IMAGE" "$PREVIOUS_REVISION" "$PREVIOUS_DIGEST"
    wait_for_host_health >/dev/null || true
  fi
}

HOST_HEALTH="$(wait_for_host_health || true)"
if ! printf '%s' "$HOST_HEALTH" | grep -q '"ok"[[:space:]]*:[[:space:]]*true'; then
  docker logs "$CONTAINER" --tail 150 >&2 || true
  restore_previous
  fail "production health check failed; previous image restoration attempted"
fi

if ! ADMIN_CANARY="$(docker exec -i "$CONTAINER" python3 - "$EXPECTED_REVISION" "$DIGEST" <<'PY'
import hashlib
import json
import os
import sys
import urllib.request

expected_revision, expected_digest = sys.argv[1:3]
base_url = "http://127.0.0.1:8787"
admin_key = os.environ.get("ADMIN_API_KEY", "").strip()
if not admin_key:
    raise SystemExit("admin canary blocked: ADMIN_API_KEY is missing")


def fetch(path: str, *, authenticated: bool = False):
    headers = {"Accept": "application/json"}
    if authenticated:
        headers["Authorization"] = f"Bearer {admin_key}"
    request = urllib.request.Request(base_url + path, headers=headers)
    with urllib.request.urlopen(request, timeout=12) as response:
        body = response.read(2_000_000)
        return response.status, response.geturl(), dict(response.headers.items()), body


def json_payload(path: str, *, authenticated: bool = False):
    status, final_url, headers, body = fetch(path, authenticated=authenticated)
    payload = json.loads(body.decode("utf-8"))
    if status != 200 or not isinstance(payload, dict):
        raise RuntimeError(f"invalid response contract: {path}")
    return payload, {
        "httpStatus": status,
        "responseSha256": hashlib.sha256(body).hexdigest(),
        "finalPath": final_url.removeprefix(base_url),
        "requestIdPresent": bool(headers.get("X-Request-ID")),
    }

health, health_evidence = json_payload("/health")
ready, ready_evidence = json_payload("/health/ready")
if health.get("ok") is not True or ready.get("ok") is not True:
    raise RuntimeError("health or readiness is not green")
if health.get("sourceRevision") != expected_revision or health.get("imageDigest") != expected_digest:
    raise RuntimeError("health runtime identity mismatch")

admin_status, admin_url, admin_headers, admin_body = fetch("/admin")
admin_producer = admin_headers.get("X-Sovereign-Admin-Producer", "")
if admin_status != 200 or not admin_url.endswith("/admin/"):
    raise RuntimeError("canonical admin route is not served")
if admin_producer != "CANONICAL_REACT_ADMIN":
    raise RuntimeError("canonical React admin producer header is missing")
if b'<div id="root"' not in admin_body:
    raise RuntimeError("canonical React admin root artifact is missing")

identity, identity_evidence = json_payload("/api/admin/platform/v1/identity", authenticated=True)
runtime = identity.get("runtime") if isinstance(identity.get("runtime"), dict) else {}
if runtime.get("sourceRevision") != expected_revision or runtime.get("imageDigest") != expected_digest:
    raise RuntimeError("enterprise identity mismatch")
if runtime.get("sourceRevisionVerified") is not True or runtime.get("imageDigestVerified") is not True:
    raise RuntimeError("enterprise identity is not verified")

overview, overview_evidence = json_payload("/api/admin/platform/v1/overview", authenticated=True)
integrations, integrations_evidence = json_payload("/api/admin/platform/v1/integrations", authenticated=True)
evidence, evidence_evidence = json_payload("/api/admin/platform/v1/evidence?limit=30", authenticated=True)
integration_rows = integrations.get("integrations") if isinstance(integrations.get("integrations"), list) else []
evidence_rows = evidence.get("evidence") if isinstance(evidence.get("evidence"), list) else []
if not integration_rows or not isinstance(overview.get("integrations"), list):
    raise RuntimeError("enterprise overview or integrations contain no live data")
if evidence.get("count") != len(evidence_rows):
    raise RuntimeError("enterprise evidence count mismatch")
required_rows = [item for item in integration_rows if isinstance(item, dict) and item.get("required")]
required_verified = [item for item in required_rows if item.get("status") == "verified"]

result = {
    "ok": True,
    "status": "ENTERPRISE_ADMIN_LIVE_CANARY_VERIFIED",
    "sourceRevision": expected_revision,
    "imageDigest": expected_digest,
    "health": health_evidence,
    "readiness": ready_evidence,
    "admin": {
        "httpStatus": admin_status,
        "finalPath": admin_url.removeprefix(base_url),
        "producer": admin_producer,
        "reactRootPresent": True,
        "responseSha256": hashlib.sha256(admin_body).hexdigest(),
    },
    "identity": identity_evidence,
    "overview": {
        **overview_evidence,
        "ok": bool(overview.get("ok")),
        "status": str(overview.get("status") or "")[:40],
        "integrationCount": len(overview.get("integrations") or []),
    },
    "integrations": {
        **integrations_evidence,
        "ok": bool(integrations.get("ok")),
        "count": len(integration_rows),
        "requiredCount": len(required_rows),
        "requiredVerifiedCount": len(required_verified),
    },
    "evidence": {
        **evidence_evidence,
        "count": len(evidence_rows),
    },
    "secretValuesReturned": False,
}
print(json.dumps(result, sort_keys=True, separators=(",", ":")))
PY
)"; then
  docker logs "$CONTAINER" --tail 150 >&2 || true
  restore_previous
  fail "enterprise admin live canary failed; previous image restoration attempted"
fi

ADMIN_CANARY_SHA256="$(printf '%s' "$ADMIN_CANARY" | sha256sum | awk '{print $1}')"
ROLLBACK_RECEIPT="$(python3 - "$PREVIOUS_DIGEST" "$PREVIOUS_REVISION" "$DIGEST" "$EXPECTED_REVISION" "$ADMIN_CANARY_SHA256" <<'PY'
import json
import sys

previous_digest, previous_revision, deployed_digest, deployed_revision, admin_sha256 = sys.argv[1:]
payload = {
    "schemaVersion": "sovereign.backend-rollback-receipt.v1",
    "previousImageDigest": previous_digest or None,
    "previousRevision": previous_revision or None,
    "deployedImageDigest": deployed_digest,
    "deployedRevision": deployed_revision,
    "adminCanarySha256": admin_sha256,
    "rollbackPreviewVerified": bool(previous_digest and previous_revision),
    "secretValuesReturned": False,
}
print(json.dumps(payload, sort_keys=True, separators=(",", ":")))
PY
)"
ROLLBACK_RECEIPT_SHA256="$(printf '%s' "$ROLLBACK_RECEIPT" | sha256sum | awk '{print $1}')"
ROLLBACK_RECEIPT_DIR="$(dirname "$ROLLBACK_RECEIPT_FILE")"
mkdir -p "$ROLLBACK_RECEIPT_DIR"
chmod 0700 "$ROLLBACK_RECEIPT_DIR"
ROLLBACK_RECEIPT_TMP="$(mktemp "$ROLLBACK_RECEIPT_DIR/.backend-rollback-receipt.XXXXXX")"
printf '%s\n' "$ROLLBACK_RECEIPT" > "$ROLLBACK_RECEIPT_TMP"
chmod 0600 "$ROLLBACK_RECEIPT_TMP"
mv -f "$ROLLBACK_RECEIPT_TMP" "$ROLLBACK_RECEIPT_FILE"

printf '{"ok":true,"status":"DEPLOYED_ADMIN_VERIFIED","container":"%s","image":"%s","imageDigest":"%s","revision":"%s","health":%s,"adminCanary":%s,"rollback":{"previousImageDigest":"%s","previousRevision":"%s","previewVerified":%s,"receiptSha256":"%s"},"readbackVerified":true,"mutationPerformed":true,"secretValuesReturned":false}\n' \
  "$CONTAINER" "$NEW_IMAGE" "$DIGEST" "$EXPECTED_REVISION" "$HOST_HEALTH" "$ADMIN_CANARY" \
  "$PREVIOUS_DIGEST" "$PREVIOUS_REVISION" "$([[ -n "$PREVIOUS_DIGEST" && -n "$PREVIOUS_REVISION" ]] && printf true || printf false)" "$ROLLBACK_RECEIPT_SHA256"
