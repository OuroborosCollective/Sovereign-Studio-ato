# Copy to /opt/sovereign-chatgpt-tools/.env on the VPS.
# Never commit the real file and never paste secret values into chat or logs.

SOVEREIGN_MCP_REPOSITORY=OuroborosCollective/Sovereign-Studio-ato
SOVEREIGN_MCP_WORKSPACE_ROOT=/opt/sovereign-chatgpt-tools/workspaces
SOVEREIGN_MCP_ALLOWED_BASE_BRANCHES=main
SOVEREIGN_MCP_ALLOWED_CONTAINERS=sovereign-backend,sovereign-chatgpt-mcp
SOVEREIGN_MCP_COMMAND_TIMEOUT=900
SOVEREIGN_MCP_GIT_AUTHOR_NAME=Sovereign ChatGPT Operator
SOVEREIGN_MCP_GIT_AUTHOR_EMAIL=sovereign-operator@users.noreply.github.com
SOVEREIGN_MCP_BROKER_SOCKET=/run/sovereign-chatgpt-broker/operator.sock

# Fine-grained token for this repository. Main push requires Contents read/write.
GITHUB_TOKEN=

# Set to 1 only for the first VPS installation to create limited DB roles and preview DB.
SOVEREIGN_MCP_BOOTSTRAP_DATABASE=0

# Read-only production database identity for canaries and schema/vector inspection.
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=sovereign_mcp_reader
POSTGRES_PASSWORD=

# Dedicated disposable/preview database.
SOVEREIGN_MCP_PREVIEW_POSTGRES_HOST=db
SOVEREIGN_MCP_PREVIEW_POSTGRES_PORT=5432
SOVEREIGN_MCP_PREVIEW_POSTGRES_DB=sovereign_migration_preview
SOVEREIGN_MCP_PREVIEW_POSTGRES_USER=sovereign_mcp_preview
SOVEREIGN_MCP_PREVIEW_POSTGRES_PASSWORD=

# Existing guarded production capabilities.
SOVEREIGN_MCP_ENABLE_DB_WRITES=0
SOVEREIGN_MCP_ENABLE_DEPLOY=0
SOVEREIGN_MCP_ALLOW_DATA_BACKFILLS=0
SOVEREIGN_MCP_ALLOW_DESTRUCTIVE_MIGRATIONS=0

# Private ChatGPT-MCP broker administrator mode.
# ADMIN_SQL permits complete PostgreSQL SQL through the root-separated broker.
# MAIN_PUSH permits direct commit/push from an isolated workspace to refs/heads/main.
SOVEREIGN_MCP_ENABLE_ADMIN_SQL=0
SOVEREIGN_MCP_ENABLE_MAIN_PUSH=0

# Fixed backend image repository used by the host broker deploy/rollback scripts.
SOVEREIGN_BACKEND_IMAGE_REPOSITORY=ghcr.io/ouroboroscollective/sovereign-backend
SOVEREIGN_BACKEND_ENV_FILE=/opt/sovereign-backend/.env

# The MCP process does not call an OpenAI model itself and needs no OPENAI_API_KEY.
