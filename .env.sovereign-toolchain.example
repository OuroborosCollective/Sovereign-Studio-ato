# Sovereign Toolchain Environment Template
# =========================================

# WICHTIG: Niemals echte Tokens in den Chat hochladen oder in Version Control committen!


# Option A: GitHub Actions Secret (EMPFOHLEN für Agent-Workflows)
# -----------------------------------------------------------------
# Der Token ist bereits als "SOVEREIGN_GITHUB_TOKEN" in GitHub Secrets gesetzt.
# Workflows nutzen automatisch: ${{ secrets.SOVEREIGN_GITHUB_TOKEN }}
# Der Agent sieht NIEMALS den echten Token - nur "secrets.SOVEREIGN_GITHUB_TOKEN"
#
# Workflow: Sovereign Toolchain Runner
# - Navigiere zu: https://github.com/OuroborosCollective/Sovereign-Studio-ato/actions/workflows/sovereign-toolchain-runner.yml
# - Klicke "Run workflow"
# - Alle Parameter sind über Eingabefelder konfigurierbar


# Option B: Lokale Nutzung (nur für direkte Shell-Nutzung)
# -----------------------------------------------------------------
# 1. Kopiere diese Datei:
#    cp .env.sovereign-toolchain.example .env.sovereign-toolchain
#
# 2. Trage den Token manuell in .env.sovereign-toolchain ein:
#    GITHUB_TOKEN=ghp_DEIN_TOKEN_HIER
#
# 3. Lade die Umgebungsvariablen:
#    set -a && source .env.sovereign-toolchain && set +a
#
# 4. Führe das Script aus:
#    bash scripts/patches/apply_toolchain_patch_guardrails_via_github_api.sh


# =============================================================================
# Konfigurationsvariablen
# =============================================================================

REPO_FULL_NAME=OuroborosCollective/Sovereign-Studio-ato
BASE_BRANCH=main
PATCH_BRANCH=sovereign/apply-toolchain-guardrails
TARGET_PATH=scripts/sovereign-backend/app.py
COMMIT_MESSAGE=fix(toolchain): apply backend patch guardrails
PR_TITLE=fix(toolchain): apply backend patch guardrails
PR_BODY=Applies the verified Toolchain backend guardrails patch from scripts/patches/apply_toolchain_patch_guardrails.py.


# Token-Rechte für Fine-grained GitHub Token
# ===========================================
# Falls ein neuer Token benötigt wird:
#
# Repository: OuroborosCollective/Sovereign-Studio-ato
#
# Permissions:
# - Contents: Read and write
# - Pull requests: Read and write
# - Metadata: Read
#
# Optional (falls Workflows gelesen werden sollen):
# - Actions: Read
